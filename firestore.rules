rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Role via Custom Claim no JWT — zero leitura de banco, instantâneo
    function isAdmin() {
      return request.auth != null && request.auth.token.role == "ADMIN";
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Usuários — cliente lê/atualiza apenas o próprio perfil, nunca muda role
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == "CUSTOMER"
        && request.resource.data.active == true;
      allow update: if isOwner(userId)
        // Impede o cliente de alterar role, active ou createdAt
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["role", "active", "createdAt"]);
      allow delete: if isAdmin();
    }

    // Categorias — leitura pública, escrita só admin
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Produtos e variantes — leitura pública, escrita só admin
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /variants/{variantId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Pedidos — cliente cria e lê os próprios, admin tem acesso total
    // Escrita de estoque e movimentações ocorre exclusivamente via Cloud Functions
    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn()
        // Garante que o cliente só cria pedidos para si mesmo
        && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Movimentações de estoque — somente via Cloud Functions (admin)
    match /stock_movements/{movementId} {
      allow read: if isAdmin();
      allow write: if false; // Apenas Cloud Functions podem escrever
    }

    // Configurações da loja — leitura pública, escrita só admin
    match /store_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Carrinhos — cada usuário acessa apenas o próprio
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
